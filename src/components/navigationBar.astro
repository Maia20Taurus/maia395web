---
import Logo from '../assets/maia395logo.svg';
---

<style>
    .bar {
        background-color: #222222;
        position: fixed;
        left: 50%;
        height: 40px;
        top: 10px;
        transform: translate(-50%, 0);
        border-radius: 25px;
        display: flex;
        justify-content: flex-start;
        align-items:center;
        padding: 0px;
        padding-left: 20px;
        padding-right: 20px;
        gap: 30px;
        box-shadow: 0px 1px 5px -1px grey;
    }

    .navButton {
        font-size: 35px;
        font-weight: bold;
        color: white;
        padding-top: 8px;
        width:100%;
        height:100%;
        bottom:0%;
    }

    .navLink {
        text-decoration: none;
        color: white;
    }

    a:visited {
        text-decoration: none;
        color: white;
    }
</style>

<div class="bar" style="display:flex;flex-direction:row;justify-content:space-evenly;">
    <div class="navButton"> <a class="navLink" href="/"> <Logo style="width:100%;height:100%;"/> </a> </div>
    <div class="navButton"> <a class="navLink" href="/trains"> Trains </a> </div>
    <div class="navButton"> <a class="navLink" href="/meshtastic"> Mesh </a> </div>
</div>

