<style>
    .bar {
        background-color: #edeff0;
        position: fixed;
        left: 50%;
        width:300px;
        min-width:300px;
        height: 40px;
        top: 10px;
        transform: translate(-50%, 0);
        border-radius: 25px;
        display: flex;
        justify-content: center;
        align-items:center;
        box-shadow: 0px 1px 5px -1px grey;
    }

    .navButton {
        font-size: 20px;
        font-weight: bold;
        color: #1E1E50;
        width:100%;
        height:100%;
        display:flex;
        justify-content: center;
        align-items: center;
    }

    .navLink {
        text-decoration: none;
        color: #1E1E50;
    }

    a:visited {
        text-decoration: none;
        color: #1E1E50;
    }
</style>

<div class="bar">
    <div class="navButton"> <a class="navLink" href="/"> Home </a> </div>
    <div class="navButton"> <a class="navLink" href="/trains"> Trains </a> </div>
    <div class="navButton"> <a class="navLink" href="/meshtastic"> Mesh </a> </div>
</div>

